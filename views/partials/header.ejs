<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Prayas Bike Ambulance System</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body>

<div class="top-bar">
    <div>About Us | Contact Us</div>
    <div>Emergency Rescue Helpline +91 98251 19081</div>
</div>

<header class="main-header">
    <img src="/images/prayas-logo.png" class="main-logo">

    <div class="header-links">

        <% if (typeof user !== "undefined" && user && user.role === "driver") { %>

            <a href="/driver-dashboard">Dashboard</a>
            <span>|</span>
            <a href="/driver-calls">My Calls</a>
            <span>|</span>
            <a href="/logout">Logout</a>

        <% } else { %>

            <a href="/dashboard">Dashboard</a>
            <span>|</span>
            <a href="/new-call">New Call</a>
            <span>|</span>
            <a href="/reports">Reports</a>
            <span>|</span>
            <a href="/change-password">Change Password</a>
            <span>|</span>
            <a href="/logout">Logout</a>

        <% } %>

    </div>
</header>